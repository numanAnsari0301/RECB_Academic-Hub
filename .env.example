# Use a unique, long random value in production.
SESSION_SECRET=replace-with-a-long-random-secret

# MongoDB connection (local or MongoDB Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/recb_education

# Required only on the first start, when no admin account exists yet.
ADMIN_USERNAME=portal-admin
ADMIN_PASSWORD=replace-with-a-password-of-at-least-10-characters
